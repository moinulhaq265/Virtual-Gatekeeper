{
  "manifest_version": 3,
  "name": "Virtual Gatekeeper",
  "version": "1.0",
  "description": "Manage online meetings with Identity Verification and Automated Attendance Tracking. Managed by Moin Ul Haq.",
  "author": "Moin Ul Haq",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://zoom.us/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://zoom.us/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
